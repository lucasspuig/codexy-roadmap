# ─── Supabase ───────────────────────────────────────────────────────
# Copiá este archivo a .env.local y completá los valores reales.
# En Easypanel: NO uses .env — cargá estas vars desde la UI de Environment.

# URL pública de tu proyecto Supabase (no secreta)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Clave anon — segura en cliente, respeta RLS
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service role — SOLO server, bypasa RLS, nunca exponer al navegador
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── App ────────────────────────────────────────────────────────────
# URL pública de esta app (sin barra al final)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Secret para firmar tokens de acceso público al roadmap (64+ chars random)
# Generá con: openssl rand -base64 48
ROADMAP_TOKEN_SECRET=CAMBIAR_ESTO_por_algo_random_de_al_menos_32_caracteres
